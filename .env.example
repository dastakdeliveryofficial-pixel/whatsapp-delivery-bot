# =============================================
# WHATSAPP DELIVERY BOT - Environment Variables
# =============================================
# Yeh file Railway mein "Variables" section mein add karni hai
# Yahan sirf example hai - apni real values daalein

# Meta WhatsApp API Token (developers.facebook.com se copy karein)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone Number ID (API Setup page par milega)
PHONE_NUMBER_ID=12345678901234

# Webhook Verify Token (aap khud koi bhi string rakho)
VERIFY_TOKEN=mySecretVerifyToken123

# Claude AI API Key (console.anthropic.com se)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# Rider ka WhatsApp number (country code ke saath, + nahi)
RIDER_PHONE=923001234567

# Port (Railway khud set karta hai - change mat karo)
PORT=3000
